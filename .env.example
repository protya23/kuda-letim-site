# ─────────────────────────────────────────────────────────────────────────────
# «Куда летим?» — сайт. Скопируйте в .env (локально) ИЛИ задайте в Vercel →
# Settings → Environment Variables. Все переменные ОПЦИОНАЛЬНЫ — сайт работает
# и без них (предложения, каталог, заявки в Telegram уже функционируют).
# ─────────────────────────────────────────────────────────────────────────────

# Базовый URL сайта (после деплоя). Нужен для АБСОЛЮТНЫХ Open Graph ссылок —
# чтобы фото офферов корректно показывались в соцсетях/мессенджерах.
# Без него OG-ссылки относительные (работают, но превью в соцсетях слабее).
# Рекомендуется задать после первого деплоя.   Пример: https://kuda-letim.vercel.app
VITE_SITE_URL=

# Google Analytics 4 measurement id. Если задан — события (view_offer,
# click_telegram, click_booking, submit_lead, filter_change) поедут в GA4.
# Опционально.   Пример: G-XXXXXXXXXX
VITE_GA_ID=

# Plausible (альтернатива GA4) — домен сайта. Если задан — события в Plausible.
# Опционально.   Пример: kuda-letim.vercel.app
VITE_PLAUSIBLE_DOMAIN=

# Номер для WhatsApp-кнопок (только цифры, с кодом страны). Если задан —
# на карточках/страницах появляется связь через WhatsApp + трекинг click_whatsapp.
# Опционально.   Пример: 79991234567
WHATSAPP_PHONE=

# Уведомления о заявках в Telegram (serverless /api/lead). ОТДЕЛЬНЫЕ от
# контент-бота переменные — бот не трогаем. Если заданы ОБЕ — каждая заявка
# с сайта приходит админу в Telegram (надёжный канал лидов на Vercel, где
# файловая система эфемерна). Опционально, но РЕКОМЕНДУЕТСЯ для прод.
#   LEAD_TG_TOKEN — токен любого бота, который может писать админу (можно тот же).
#   LEAD_TG_CHAT  — ваш chat_id (узнать у @userinfobot).
LEAD_TG_TOKEN=
LEAD_TG_CHAT=
