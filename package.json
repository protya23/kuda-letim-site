{
  "name": "kuda-letim-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "offers": "node scripts/gen-offers.mjs",
    "dev": "npm run offers && vite",
    "build": "npm run offers && tsc -b && vite build && node scripts/gen-offer-pages.mjs && node scripts/gen-sitemap.mjs",
    "preview": "vite preview",
    "site:check": "npm run build && node scripts/site-check.mjs",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-3000}"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
